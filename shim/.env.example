# Willys account (outbound) — already in atlas .env on the Pi
WILLYS_USERNAME=
WILLYS_PASSWORD=

# Shim auth (inbound) — generate: openssl rand -hex 32  (client_id: openssl rand -hex 16)
WILLYS_MCP_TOKEN=
WILLYS_OAUTH_CLIENT_ID=
WILLYS_OAUTH_CLIENT_SECRET=

# Wiring (atlas injects in prod)
WILLYS_MCP_PORT=8426
WILLYS_MCP_HOST=localhost
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
WILLYS_BACKEND_CMD=../node_modules/.bin/tsx
WILLYS_BACKEND_CWD=..
